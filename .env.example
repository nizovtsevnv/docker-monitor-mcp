# Copy to .env for local runs. All variables are optional — defaults target a
# local run reading the real /proc and / (see docs/SPEC.md §4).

# Address the MCP HTTP endpoint binds to.
BIND_ADDR=0.0.0.0:8080

# Path to the Docker socket (mounted read-only in containers).
DOCKER_SOCKET=/var/run/docker.sock

# procfs root. In a container, mount the host's /proc and set HOST_PROC=/host/proc.
HOST_PROC=/proc

# Host filesystem root for disk statvfs. In a container, mount / and set
# HOST_ROOTFS=/host/rootfs.
HOST_ROOTFS=/

# Optional bearer token. Leave unset/empty to disable auth (default). When set,
# MCP endpoints require the header `Authorization: Bearer <token>`.
# AUTH_TOKEN=change-me

# Log level (stderr).
RUST_LOG=info
